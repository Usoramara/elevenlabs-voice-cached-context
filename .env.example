# ── Required ──
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key
DATABASE_URL=postgresql://...          # Neon PostgreSQL connection string

# ── ElevenLabs ──
ELEVENLABS_AGENT_ID=agent_...          # Your ElevenLabs Conversational AI agent ID
ELEVENLABS_LLM_SECRET=your-secret      # Bearer token for LLM proxy auth
ELEVENLABS_WEBHOOK_SECRET=your-secret  # Webhook signature verification

# ── Optional ──
VOICE_DEFAULT_USER_ID=voice-user       # User ID when no auth is present
NODE_ENV=development                   # Set to 'production' in production
